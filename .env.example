# No model API key is needed for the default local deployment. `codex exec`
# reuses the host's ChatGPT login through a read-write auth.json bind mount.
#
# All market and macro data comes from keyless public endpoints, executed from
# declarative fetch specs the agent writes itself. See docs/RUNTIME.md §3.
#
# If you find yourself adding a key here, stop and ask whether the loop still
# runs for someone who clones this repo. That is the constraint.

LAB_DATABASE_URL=postgresql://lab:lab@localhost:5432/lab

# Postgres password for the single compose database. A default exists for local demo use.
LAB_DB_PASSWORD=lab

# Host port for the read-only chart server. Change if 8080 is already occupied.
LAB_CHARTS_PORT=8080
# Host port for the first-party React journal.
LAB_JOURNAL_PORT=8421

# MT5 demo account for the gateway's headless login (gateway 0.3.x). The
# gateway logs in on boot; idempotent across restarts. MT5_API_KEY protects
# the gateway's REST surface and is handed to qkt as QKT_BROKER_*_API_KEY.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_API_KEY=
