#!/usr/bin/env python3
"""Nightly distillation: propose -> validate -> score -> calibrate."""
import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from lab import config as cfgmod
from lab.distill import run
from lab.store import Store


def main() -> int:
    cfg = cfgmod.load(Path(__file__).resolve().parents[1] / "lab.yaml")
    report = run(cfg, Store(cfg.store_dsn))
    print(json.dumps(report, indent=2, default=str))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
