#!/usr/bin/env python3
"""Join realized outcomes onto open decisions. Idempotent; cron every 15m."""
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from lab import config as cfgmod
from lab.join import run
from lab.qkt import Qkt
from lab.store import Store


def main() -> int:
    cfg = cfgmod.load(Path(__file__).resolve().parents[1] / "lab.yaml")
    qkt = Qkt(cfg.qkt_bin, cfg.qkt_config, cfg.qkt_timeout_s, cfg.qkt_retries)
    store = Store(cfg.store_dsn)
    r = run(cfg, qkt, store)
    print(f"checked {r['checked']}, joined {r['joined']}, open {r['still_open']}")
    for a in r["alarms"]:
        print(f"ALARM: {a}", file=sys.stderr)
    return 1 if r["alarms"] else 0


if __name__ == "__main__":
    raise SystemExit(main())
