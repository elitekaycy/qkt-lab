#!/usr/bin/env python3
"""Export closed trades to Deltalytix. Optional plugin — the loop runs without it."""
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from exporters.deltalytix import Target, export
from lab import config as cfgmod
from lab.store import Store


def main() -> int:
    cfg = cfgmod.load(Path(__file__).resolve().parents[1] / "lab.yaml")
    j = cfg.raw.get("journal", {}).get("deltalytix", {})
    if not j.get("enabled"):
        print("deltalytix export disabled (journal.deltalytix.enabled)")
        return 0

    store = Store(cfg.store_dsn)
    episodes = store.query("SELECT * FROM episode ORDER BY closed_at")
    t = Target(
        dsn=j["dsn"],
        user_id=j.get("user_id", "local-dashboard-user"),
        user_email=j.get("user_email", "local-dashboard@deltalytix.local"),
        account_number=j.get("account_number", "LAB"),
        starting_balance=float(j.get("starting_balance", 10000)),
        charts_base_url=j.get("charts_base_url", "http://localhost:8080/charts"),
    )
    r = export(episodes, t)
    print(f"exported {r['exported']} episodes, {r['inserted']} new rows")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
