#!/usr/bin/env python3
"""One trade cycle for one instrument. Cron-driven; exits when done."""
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from lab import config as cfgmod
from lab.cycle import run
from lab.qkt import Qkt
from lab.store import Store


def main() -> int:
    symbol = sys.argv[1] if len(sys.argv) > 1 else None
    cfg = cfgmod.load(Path(__file__).resolve().parents[1] / "lab.yaml")
    qkt = Qkt(cfg.qkt_bin, cfg.qkt_config, cfg.qkt_timeout_s, cfg.qkt_retries)
    store = Store(cfg.store_dsn)

    instruments = [cfg.instrument(symbol)] if symbol else cfg.instruments
    rc = 0
    for inst in instruments:
        try:
            r = run(cfg, qkt, store, inst)
            print(f"{inst.symbol}: {r.action} (decision {r.decision_id}) — {r.detail}")
        except Exception as e:  # a failed cycle must not stop the other instruments
            print(f"{inst.symbol}: CYCLE FAILED — {e}", file=sys.stderr)
            rc = 1
    return rc


if __name__ == "__main__":
    raise SystemExit(main())
